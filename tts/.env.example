# Stash TTS daemon secrets. Copy to .env and fill in.
#   cp .env.example .env   &&   edit .env
# .env is gitignored — never commit the real key.

# Supabase service-role key (Dashboard > Project Settings > API > service_role).
# Required: the daemon writes to Storage and the saves table, which RLS blocks
# for the publishable/anon key. The service role bypasses RLS.
STASH_SUPABASE_SERVICE_ROLE_KEY=

# Required: which user's saves to process (service role bypasses RLS, so
# the daemon must be told explicitly). Dashboard > Authentication > Users.
STASH_USER_ID=

# Optional override (default is baked into tts.py):
# STASH_SUPABASE_URL=https://fvydjrhqaeemkdakqnfk.supabase.co
